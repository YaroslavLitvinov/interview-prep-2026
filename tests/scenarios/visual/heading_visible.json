{
  "name": "heading_visible",
  "plugin": "visual",
  "protocol": "browser",
  "fixture": {
    "url": "${home}",
    "dom_walk": {
      "html>body>main[testid=stApp]>h1[testid=stHeading]": {
        "text": "Dashboard",
        "visible": true,
        "x": 60, "y": 60, "width": 800, "height": 56
      }
    }
  },
  "steps": [
    {"action": "expect_visible",
     "target": "html>body>main[testid=stApp]>h1[testid=stHeading]"},
    {"action": "expect_text",
     "target": "html>body>main[testid=stApp]>h1[testid=stHeading]",
     "value": "Dashboard"}
  ],
  "expectations": {
    "envelopes": ["main.tree"],
    "observations_must_include": ["page.dom_tree", "page.screen_map"]
  }
}
